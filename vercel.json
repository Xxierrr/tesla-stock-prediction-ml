{
  "version": 2,
  "builds": [
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    },
    {
      "src": "api/*.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/api/stock-data",
      "dest": "/api/stock-data.py"
    },
    {
      "src": "/api/realtime",
      "dest": "/api/realtime.py"
    },
    {
      "src": "/api/eda",
      "dest": "/api/eda.py"
    },
    {
      "src": "/api/health",
      "dest": "/api/health.py"
    },
    {
      "src": "/(.*)",
      "dest": "/frontend/$1"
    }
  ]
}
